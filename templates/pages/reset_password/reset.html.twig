{% extends 'base.html.twig' %}

{% block title %}{{ 'reset-password.title.label'|trans }}{% endblock %}

{% block body %}
<div class="container-lg">
    <h1>{{ 'reset-password.title.label'|trans }}</h1>

    {{ form_start(resetForm) }}
        {{ form_row(resetForm.plainPassword) }}
        <button class="btn btn-primary mt-4">
            <i class="bi bi-key me-1"></i>
            {{ 'reset-password.title.label'|trans }}
        </button>
    {{ form_end(resetForm) }}
</div>
{% endblock %}
