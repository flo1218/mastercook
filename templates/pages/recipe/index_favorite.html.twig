{% extends 'base.html.twig' %}
{% block title %}{{ app.request.server.get('APP_NAME') }} - Mes recettes{% endblock %}
{% block body %}
<div class="container">    
    <h1>{{ 'recipe.favorite.label'|trans }}</h1>
    <div class="count mt-4">
        <h6>{{ 'recipe.count.label'|trans({'count': recettes.getTotalItemCount}) }}</h6> 
    </div>
    {% if not recettes.items is same as([]) %}
    <table class="table table-hover">
        <thead>
            <tr>
                <th scope="col"></th>
                <th scope="col">{{ 'recipe.name.label'|trans}}</th>
                <th scope="col">{{ 'recipe.price.label'|trans}}</th>
                <th scope="col">{{ 'recipe.nbPeople.label'|trans}}</th>
                <th scope="col">{{ 'recipe.difficulty.label'|trans}}</th>
                <th scope="col">{{ 'app.createdAt.label'|trans}}</th>
                <th scope="col">{{ 'recipe.rating.label'|trans}}</th>
                <th style="width: 5%" scope="col"></th>
                <th style="width: 5%" scope="col"></th>
            </tr>
        </thead>
        <tbody>
        {% for recette in recettes %}    
            <tr class="jsTableRow">
                <td scope="row"><a href="{{ path('recipe.edit', { id : recette.id }) }}">{{recette.id}}</a></td>
                <td>{{recette.name}}</td>
                <td>{{recette.price is null ? '/' : recette.price}}</td>
                <td>{{recette.nbPeople is null ? '/' : recette.nbPeople}}</td>
                <td>{{recette.difficulty is null ? '/' : recette.difficulty}}</td>
                <td>{{recette.createdAt | format_datetime('short')}}</td>
                <td>{{recette.average|stars_rating(true)}}</td>
                <td>
                    <a href="{{ path('recipe.edit', { id : recette.id }) }}" class="btn btn-info" title="{{'app.edit.label'|trans}}">
                        <i class="bi bi-pencil-fill"></i>
                    </a>
                </td>
                <td>
                    <button type="button" class="btn btn-danger" data-bs-toggle="modal" 
                        data-href="{{ path('recipe.delete', { id : recette.id }) }}"
                        data-bs-target="#confirmDeleteModal">
                        <i class="bi bi-trash3-fill"></i>
                    </button>
                </td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
    <div class="navigation d-flex justify-content-center mt-4">
        {{ knp_pagination_render(recettes) }}
    </div>
{% endif %}
</div>
{% endblock %}
